<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#"
     xml:base="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/"
     xmlns:eudamed-mdr-ivdr="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr">
        <terms:creator>Estudiante UOC – PEC2 Representación del Conocimiento</terms:creator>
        <terms:description xml:lang="es">Ontología semántica para el catálogo europeo de dispositivos médicos de alto riesgo (MDR, Regulation EU 2017/745) y de dispositivos de diagnóstico in vitro (IVDR, Regulation EU 2017/746). Modela dispositivos, fabricantes, clases de riesgo, riesgos identificados según IMDRF, incidentes notificados y acciones correctivas de seguridad en campo (FSCA) tal y como se registran en la base de datos EUDAMED.</terms:description>
        <terms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-04-15</terms:issued>
        <terms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <terms:title xml:lang="en">EUDAMED MDR/IVDR Device Catalogue Ontology</terms:title>
        <rdfs:comment xml:lang="en">Ontology IRI: http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr</rdfs:comment>
        <owl:versionInfo>0.1.0</owl:versionInfo>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/issued -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/issued"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#affects -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#affects">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Dispositivo concreto al que se refiere un incidente.</rdfs:comment>
        <rdfs:label xml:lang="en">affects</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasCorrectiveAction -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasCorrectiveAction">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">FSCA derivada de un incidente.</rdfs:comment>
        <rdfs:label xml:lang="en">has corrective action</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasIdentifiedRisk -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasIdentifiedRisk">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo identificado que afecta a un dispositivo o a su tipología.</rdfs:comment>
        <rdfs:label xml:lang="en">has identified risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasManufacturer -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasManufacturer">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Manufacturer"/>
        <rdfs:comment xml:lang="en">Relaciona un dispositivo con su fabricante legal. Es funcional: un dispositivo tiene un único fabricante registrado.</rdfs:comment>
        <rdfs:label xml:lang="en">has manufacturer</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasRiskClass -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasRiskClass">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RiskClass"/>
        <rdfs:comment xml:lang="en">Clase de riesgo asignada al dispositivo (una y solo una conforme al MDR o IVDR).</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#locatedInCountry -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#locatedInCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Country"/>
        <rdfs:comment xml:lang="en">País en el que tiene sede legal el fabricante.</rdfs:comment>
        <rdfs:label xml:lang="en">located in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#manufacturesDevice -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#manufacturesDevice">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasManufacturer"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Inversa de hasManufacturer.</rdfs:comment>
        <rdfs:label xml:lang="en">manufactures device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#regulatedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#regulatedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Marco regulatorio bajo el que se clasifica el dispositivo (MDR o IVDR).</rdfs:comment>
        <rdfs:label xml:lang="en">regulated by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#reportedInCountry -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#reportedInCountry">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Country"/>
        <rdfs:comment xml:lang="en">Estado miembro en el que se notifica el incidente.</rdfs:comment>
        <rdfs:label xml:lang="en">reported in country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#supervisedBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#supervisedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CompetentAuthority"/>
        <rdfs:comment xml:lang="en">Autoridad competente del Estado miembro bajo cuya supervisión opera el fabricante.</rdfs:comment>
        <rdfs:label xml:lang="en">supervised by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#triggeredBy -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#triggeredBy">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Incident"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo identificado que materializa el incidente.</rdfs:comment>
        <rdfs:label xml:lang="en">triggered by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#actionDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#actionDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Fecha en la que se inicia la FSCA.</rdfs:comment>
        <rdfs:label xml:lang="en">action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#authorizationNumber -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#authorizationNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Número de autorización asignado al fabricante por la autoridad competente.</rdfs:comment>
        <rdfs:label xml:lang="en">authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#closureDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#closureDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Fecha de cierre de la FSCA (si procede).</rdfs:comment>
        <rdfs:label xml:lang="en">closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#contactEmail -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#contactEmail">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Correo de contacto regulatorio del fabricante.</rdfs:comment>
        <rdfs:label xml:lang="en">contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#deviceName -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#deviceName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Nombre comercial del dispositivo tal y como aparece en EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#devicesAffected -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#devicesAffected">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Número (aproximado) de dispositivos alcanzados por la FSCA.</rdfs:comment>
        <rdfs:label xml:lang="en">devices affected</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#eudamedSRN -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#eudamedSRN">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Single Registration Number de EUDAMED asignado al fabricante.</rdfs:comment>
        <rdfs:label xml:lang="en">EUDAMED SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#eventDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#eventDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Fecha en la que tuvo lugar el evento adverso.</rdfs:comment>
        <rdfs:label xml:lang="en">event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#fscaStatus -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#fscaStatus">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CorrectiveAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Estado de la acción correctiva (Open, Closed).</rdfs:comment>
        <rdfs:label xml:lang="en">FSCA status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#imdrfCode -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#imdrfCode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Código IMDRF Adverse Event Terminology que identifica el riesgo.</rdfs:comment>
        <rdfs:label xml:lang="en">IMDRF code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#incidentDescription -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#incidentDescription">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Descripción clínica del incidente.</rdfs:comment>
        <rdfs:label xml:lang="en">incident description</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#intendedPurpose -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#intendedPurpose">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Finalidad prevista declarada por el fabricante.</rdfs:comment>
        <rdfs:label xml:lang="en">intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#isActive -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#isActive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Valor booleano que indica si el dispositivo es activo (requiere fuente de energía externa).</rdfs:comment>
        <rdfs:label xml:lang="en">is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#isImplantable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#isImplantable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Valor booleano que indica si el dispositivo es implantable.</rdfs:comment>
        <rdfs:label xml:lang="en">is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#isIvd -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#isIvd">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Valor booleano que indica si el dispositivo es de diagnóstico in vitro.</rdfs:comment>
        <rdfs:label xml:lang="en">is IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#isReusable -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#isReusable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Valor booleano que indica si el dispositivo se utiliza en más de un paciente o procedimiento.</rdfs:comment>
        <rdfs:label xml:lang="en">is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#probability -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#probability">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Probabilidad estimada de materialización del riesgo (Low, Medium, High).</rdfs:comment>
        <rdfs:label xml:lang="en">probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#reportDate -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#reportDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment xml:lang="en">Fecha en la que el incidente fue notificado a la autoridad competente.</rdfs:comment>
        <rdfs:label xml:lang="en">report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#severity -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#severity">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Gravedad del riesgo (Moderate, Serious, Critical).</rdfs:comment>
        <rdfs:label xml:lang="en">severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#udiDi -->


    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#udiDi">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique Device Identifier – Device Identifier (GS1 AI 01). Es único e inmutable para el modelo de dispositivo.</rdfs:comment>
        <rdfs:label xml:lang="en">UDI-DI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Dispositivo médico que depende de una fuente de energía distinta de la generada directamente por el cuerpo humano o la gravedad.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ActiveImplant -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ActiveImplant">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ImplantableActiveDevice"/>
        <rdfs:comment xml:lang="en">Implante activo en el sentido del MDR, anexo VIII regla 8: dispositivo activo destinado a introducirse total o parcialmente en el cuerpo humano y permanecer tras la intervención.</rdfs:comment>
        <rdfs:label xml:lang="en">Active Implant</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CompetentAuthority -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CompetentAuthority">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatedEntity"/>
        <rdfs:comment xml:lang="en">Autoridad nacional responsable de la supervisión de los dispositivos médicos comercializados en un Estado miembro.</rdfs:comment>
        <rdfs:label xml:lang="en">Competent Authority</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ContaminationRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ContaminationRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo de contaminación del producto o de sus reactivos.</rdfs:comment>
        <rdfs:label xml:lang="en">Contamination Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CorrectiveAction -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CorrectiveAction">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatedEntity"/>
        <rdfs:comment xml:lang="en">Acción correctiva de seguridad en campo (FSCA) emprendida por el fabricante para reducir el riesgo asociado a un dispositivo comercializado.</rdfs:comment>
        <rdfs:label xml:lang="en">Field Safety Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Country -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Country">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatedEntity"/>
        <rdfs:comment xml:lang="en">Estado en el que opera un fabricante, se notifica un incidente o se ve afectada una acción correctiva.</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Country"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CybersecurityRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo derivado de vulnerabilidades de ciberseguridad del dispositivo.</rdfs:comment>
        <rdfs:label xml:lang="en">Cybersecurity Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#DiagnosticRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo específico de dispositivos IVD: falsos positivos, falsos negativos, reactividad cruzada, etc.</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#HighRiskClassCategory -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#HighRiskClassCategory">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RiskClass"/>
        <rdfs:comment xml:lang="en">Metacategoría que agrupa las clases de riesgo más altas (ClassIII en MDR, ClassD en IVDR) y que se usa como disparador de la regla SWRL de HighRiskDevice.</rdfs:comment>
        <rdfs:label xml:lang="en">High Risk Class Category</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#HighRiskDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#HighRiskDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Clase inferida que agrupa los dispositivos con clase de riesgo más alta (ClassIII bajo MDR o ClassD bajo IVDR). Se puebla mediante regla SWRL.</rdfs:comment>
        <rdfs:label xml:lang="en">High Risk Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#IVDRFramework -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#IVDRFramework">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Regulation (EU) 2017/746 on in vitro diagnostic medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#IVDRRiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#IVDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RiskClass"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MDRRiskClass"/>
        <rdfs:comment xml:lang="en">Clase de riesgo bajo el reglamento IVDR (A, B, C, D).</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ImplantableActiveDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ImplantableActiveDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ActiveDevice"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ImplantableDevice"/>
        <rdfs:comment xml:lang="en">Dispositivo que es a la vez implantable y activo. Intersección de ActiveDevice e ImplantableDevice.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ImplantableDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasRiskClass"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MDRRiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Dispositivo diseñado para ser introducido total o parcialmente en el cuerpo humano mediante intervención quirúrgica y permanecer allí tras dicho procedimiento.</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#InSituCorrection -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#InSituCorrection">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Corrección del dispositivo en el centro de uso (actualización software, cambio de consumible, reentrenamiento…).</rdfs:comment>
        <rdfs:label xml:lang="en">In Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasRiskClass"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#IVDRRiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Dispositivo destinado a examinar muestras procedentes del cuerpo humano con fines diagnósticos, según el reglamento IVDR (EU 2017/746).</rdfs:comment>
        <rdfs:label xml:lang="en">In Vitro Diagnostic Device</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Medical_test"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Incident -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Incident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatedEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#affects"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Evento adverso asociado a un dispositivo médico que es notificado a las autoridades regulatorias a través de EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#InfectionRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#InfectionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo de infección asociado al uso o implantación del dispositivo.</rdfs:comment>
        <rdfs:label xml:lang="en">Infection Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#InjuryRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#InjuryRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo de daño directo al paciente.</rdfs:comment>
        <rdfs:label xml:lang="en">Injury Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#InterferenceRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#InterferenceRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo por interferencias electromagnéticas o artefactos producidos por el dispositivo.</rdfs:comment>
        <rdfs:label xml:lang="en">Interference Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MDRFramework -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MDRFramework">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Regulation (EU) 2017/745 on medical devices.</rdfs:comment>
        <rdfs:label xml:lang="en">MDR Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MDRRiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MDRRiskClass">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RiskClass"/>
        <rdfs:comment xml:lang="en">Clase de riesgo bajo el reglamento MDR (I, IIa, IIb, III).</rdfs:comment>
        <rdfs:label xml:lang="en">MDR Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MalfunctionRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo derivado del mal funcionamiento del dispositivo (eléctrico, mecánico, de rendimiento, etc.).</rdfs:comment>
        <rdfs:label xml:lang="en">Malfunction Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Manufacturer -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Manufacturer">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatedEntity"/>
        <rdfs:comment xml:lang="en">Persona jurídica responsable del diseño, fabricación, envasado y etiquetado de un dispositivo antes de su comercialización bajo su propio nombre.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Manufacturing"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MaterialRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MaterialRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo derivado de los materiales del dispositivo (desgaste, corrosión, toxicidad).</rdfs:comment>
        <rdfs:label xml:lang="en">Material Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice">
        <owl:equivalentClass>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasManufacturer"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Manufacturer"/>
            </owl:Restriction>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatedEntity"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasManufacturer"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#hasRiskClass"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Dispositivo médico registrado en EUDAMED. Cualquier instrumento, aparato o software destinado a un uso médico según los reglamentos MDR o IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Device</rdfs:label>
        <rdfs:seeAlso rdf:resource="http://dbpedia.org/resource/Medical_device"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#NearMissIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#NearMissIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Incident"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#SeriousIncident"/>
        <rdfs:comment xml:lang="en">Cuasi-incidente detectado sin consecuencias finales sobre el paciente.</rdfs:comment>
        <rdfs:label xml:lang="en">Near-Miss Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RadiationRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RadiationRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo asociado a la exposición inadvertida o excesiva a radiación ionizante o no ionizante.</rdfs:comment>
        <rdfs:label xml:lang="en">Radiation Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Recall -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Recall">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Retirada de producto del mercado.</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RecalledDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RecalledDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Clase inferida que agrupa los dispositivos asociados a una acción correctiva de tipo Recall. Se puebla mediante regla SWRL.</rdfs:comment>
        <rdfs:label xml:lang="en">Recalled Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatedEntity -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatedEntity">
        <rdfs:comment xml:lang="en">Clase raíz que agrupa cualquier entidad sujeta a los reglamentos MDR (EU 2017/745) e IVDR (EU 2017/746).</rdfs:comment>
        <rdfs:isDefinedBy rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr"/>
        <rdfs:label xml:lang="en">Regulated Entity</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatoryFramework -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatoryFramework">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatedEntity"/>
        <rdfs:comment xml:lang="en">Reglamento europeo bajo el que se clasifica y vigila un dispositivo.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatedEntity"/>
        <rdfs:comment xml:lang="en">Riesgo identificado que puede asociarse a un tipo de dispositivo, codificado conforme a la nomenclatura IMDRF.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RiskClass -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RiskClass">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#RegulatedEntity"/>
        <rdfs:comment xml:lang="en">Categoría de riesgo asignada a un dispositivo conforme al anexo correspondiente del MDR o del IVDR.</rdfs:comment>
        <rdfs:label xml:lang="en">Risk Class</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#SafetyAlert -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#SafetyAlert">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Comunicación de seguridad sin retirada del producto.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#SelfTestDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#SelfTestDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#InVitroDiagnosticDevice"/>
        <rdfs:comment xml:lang="en">Dispositivo IVD destinado a ser utilizado por personas legas en el ámbito doméstico (autodiagnóstico).</rdfs:comment>
        <rdfs:label xml:lang="en">Self Test Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#SeriousIncident -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#SeriousIncident">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Incident"/>
        <rdfs:comment xml:lang="en">Incidente grave que provoca, o pudo haber provocado, la muerte del paciente o un deterioro grave de su salud.</rdfs:comment>
        <rdfs:label xml:lang="en">Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#SingleUseDevice -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#SingleUseDevice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Dispositivo destinado a utilizarse en un único paciente durante un único procedimiento.</rdfs:comment>
        <rdfs:label xml:lang="en">Single Use Device</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#SoftwareRisk -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#SoftwareRisk">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#Risk"/>
        <rdfs:comment xml:lang="en">Riesgo relacionado con defectos del software embebido o de control del dispositivo.</rdfs:comment>
        <rdfs:label xml:lang="en">Software Risk</rdfs:label>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#UserNotice -->


    <owl:Class rdf:about="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#UserNotice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#CorrectiveAction"/>
        <rdfs:comment xml:lang="en">Notificación al usuario con instrucciones de uso actualizadas.</rdfs:comment>
        <rdfs:label xml:lang="en">User Notice</rdfs:label>
    </owl:Class>
    


