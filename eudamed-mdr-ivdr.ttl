@prefix :      <http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:   <http://purl.org/dc/terms/> .
@prefix foaf:  <http://xmlns.com/foaf/0.1/> .
@prefix swrl:  <http://www.w3.org/2003/11/swrl#> .
@prefix swrlb: <http://www.w3.org/2003/11/swrlb#> .
@prefix vcard: <http://www.w3.org/2006/vcard/ns#> .
@prefix schema: <http://schema.org/> .
@prefix dbo:   <http://dbpedia.org/ontology/> .
@prefix dbr:   <http://dbpedia.org/resource/> .

#################################################################
#  Metadatos de la ontología
#################################################################

<http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr> a owl:Ontology ;
    dct:title        "EUDAMED MDR/IVDR Device Catalogue Ontology"@en ;
    dct:description  "Ontología semántica para el catálogo europeo de dispositivos médicos de alto riesgo (MDR, Regulation EU 2017/745) y de dispositivos de diagnóstico in vitro (IVDR, Regulation EU 2017/746). Modela dispositivos, fabricantes, clases de riesgo, riesgos identificados según IMDRF, incidentes notificados y acciones correctivas de seguridad en campo (FSCA) tal y como se registran en la base de datos EUDAMED."@es ;
    dct:creator      "Estudiante UOC – PEC2 Representación del Conocimiento" ;
    dct:license      <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionInfo  "0.1.0" ;
    dct:issued       "2026-04-15"^^xsd:date ;
    rdfs:comment     "Ontology IRI: http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr"@en .

#################################################################
#  CLASES
#################################################################

### Raíz conceptual

:RegulatedEntity a owl:Class ;
    rdfs:label   "Regulated Entity"@en ;
    rdfs:comment "Clase raíz que agrupa cualquier entidad sujeta a los reglamentos MDR (EU 2017/745) e IVDR (EU 2017/746)."@en ;
    rdfs:isDefinedBy <http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr> .

### Dispositivos

:MedicalDevice a owl:Class ;
    rdfs:subClassOf  :RegulatedEntity ;
    rdfs:label       "Medical Device"@en ;
    rdfs:comment     "Dispositivo médico registrado en EUDAMED. Cualquier instrumento, aparato o software destinado a un uso médico según los reglamentos MDR o IVDR."@en ;
    rdfs:seeAlso     dbr:Medical_device ;
    owl:equivalentClass [
        a owl:Restriction ;
        owl:onProperty  :hasManufacturer ;
        owl:someValuesFrom :Manufacturer
    ] .

:ActiveDevice a owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label      "Active Device"@en ;
    rdfs:comment    "Dispositivo médico que depende de una fuente de energía distinta de la generada directamente por el cuerpo humano o la gravedad."@en .

:ImplantableDevice a owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label      "Implantable Device"@en ;
    rdfs:comment    "Dispositivo diseñado para ser introducido total o parcialmente en el cuerpo humano mediante intervención quirúrgica y permanecer allí tras dicho procedimiento."@en .

:ImplantableActiveDevice a owl:Class ;
    rdfs:subClassOf :ActiveDevice , :ImplantableDevice ;
    rdfs:label      "Implantable Active Device"@en ;
    rdfs:comment    "Dispositivo que es a la vez implantable y activo. Intersección de ActiveDevice e ImplantableDevice."@en .

:ActiveImplant a owl:Class ;
    rdfs:subClassOf :ImplantableActiveDevice ;
    rdfs:label      "Active Implant"@en ;
    rdfs:comment    "Implante activo en el sentido del MDR, anexo VIII regla 8: dispositivo activo destinado a introducirse total o parcialmente en el cuerpo humano y permanecer tras la intervención."@en .

:SingleUseDevice a owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label      "Single Use Device"@en ;
    rdfs:comment    "Dispositivo destinado a utilizarse en un único paciente durante un único procedimiento."@en .

:InVitroDiagnosticDevice a owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label      "In Vitro Diagnostic Device"@en ;
    rdfs:comment    "Dispositivo destinado a examinar muestras procedentes del cuerpo humano con fines diagnósticos, según el reglamento IVDR (EU 2017/746)."@en ;
    rdfs:seeAlso    dbr:Medical_test .

:SelfTestDevice a owl:Class ;
    rdfs:subClassOf :InVitroDiagnosticDevice ;
    rdfs:label      "Self Test Device"@en ;
    rdfs:comment    "Dispositivo IVD destinado a ser utilizado por personas legas en el ámbito doméstico (autodiagnóstico)."@en .

:HighRiskDevice a owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label      "High Risk Device"@en ;
    rdfs:comment    "Clase inferida que agrupa los dispositivos con clase de riesgo más alta (ClassIII bajo MDR o ClassD bajo IVDR). Se puebla mediante regla SWRL."@en .

:RecalledDevice a owl:Class ;
    rdfs:subClassOf :MedicalDevice ;
    rdfs:label      "Recalled Device"@en ;
    rdfs:comment    "Clase inferida que agrupa los dispositivos asociados a una acción correctiva de tipo Recall. Se puebla mediante regla SWRL."@en .

### Clases de riesgo regulatorio

:RiskClass a owl:Class ;
    rdfs:subClassOf :RegulatedEntity ;
    rdfs:label      "Risk Class"@en ;
    rdfs:comment    "Categoría de riesgo asignada a un dispositivo conforme al anexo correspondiente del MDR o del IVDR."@en .

:MDRRiskClass a owl:Class ;
    rdfs:subClassOf :RiskClass ;
    rdfs:label      "MDR Risk Class"@en ;
    rdfs:comment    "Clase de riesgo bajo el reglamento MDR (I, IIa, IIb, III)."@en .

:IVDRRiskClass a owl:Class ;
    rdfs:subClassOf :RiskClass ;
    rdfs:label      "IVDR Risk Class"@en ;
    rdfs:comment    "Clase de riesgo bajo el reglamento IVDR (A, B, C, D)."@en .

:HighRiskClassCategory a owl:Class ;
    rdfs:subClassOf :RiskClass ;
    rdfs:label      "High Risk Class Category"@en ;
    rdfs:comment    "Metacategoría que agrupa las clases de riesgo más altas (ClassIII en MDR, ClassD en IVDR) y que se usa como disparador de la regla SWRL de HighRiskDevice."@en .

### Fabricantes y autoridades

:Manufacturer a owl:Class ;
    rdfs:subClassOf :RegulatedEntity ;
    rdfs:label      "Manufacturer"@en ;
    rdfs:comment    "Persona jurídica responsable del diseño, fabricación, envasado y etiquetado de un dispositivo antes de su comercialización bajo su propio nombre."@en ;
    rdfs:seeAlso    dbr:Manufacturing .

:CompetentAuthority a owl:Class ;
    rdfs:subClassOf :RegulatedEntity ;
    rdfs:label      "Competent Authority"@en ;
    rdfs:comment    "Autoridad nacional responsable de la supervisión de los dispositivos médicos comercializados en un Estado miembro."@en .

:Country a owl:Class ;
    rdfs:subClassOf :RegulatedEntity ;
    rdfs:label      "Country"@en ;
    rdfs:comment    "Estado en el que opera un fabricante, se notifica un incidente o se ve afectada una acción correctiva."@en ;
    rdfs:seeAlso    dbr:Country .

### Marco regulatorio

:RegulatoryFramework a owl:Class ;
    rdfs:subClassOf :RegulatedEntity ;
    rdfs:label      "Regulatory Framework"@en ;
    rdfs:comment    "Reglamento europeo bajo el que se clasifica y vigila un dispositivo."@en .

:MDRFramework a owl:Class ;
    rdfs:subClassOf :RegulatoryFramework ;
    rdfs:label      "MDR Framework"@en ;
    rdfs:comment    "Regulation (EU) 2017/745 on medical devices."@en .

:IVDRFramework a owl:Class ;
    rdfs:subClassOf :RegulatoryFramework ;
    rdfs:label      "IVDR Framework"@en ;
    rdfs:comment    "Regulation (EU) 2017/746 on in vitro diagnostic medical devices."@en .

### Riesgos

:Risk a owl:Class ;
    rdfs:subClassOf :RegulatedEntity ;
    rdfs:label      "Risk"@en ;
    rdfs:comment    "Riesgo identificado que puede asociarse a un tipo de dispositivo, codificado conforme a la nomenclatura IMDRF."@en .

:MalfunctionRisk a owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label      "Malfunction Risk"@en ;
    rdfs:comment    "Riesgo derivado del mal funcionamiento del dispositivo (eléctrico, mecánico, de rendimiento, etc.)."@en .

:InjuryRisk a owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label      "Injury Risk"@en ;
    rdfs:comment    "Riesgo de daño directo al paciente."@en .

:InfectionRisk a owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label      "Infection Risk"@en ;
    rdfs:comment    "Riesgo de infección asociado al uso o implantación del dispositivo."@en .

:SoftwareRisk a owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label      "Software Risk"@en ;
    rdfs:comment    "Riesgo relacionado con defectos del software embebido o de control del dispositivo."@en .

:RadiationRisk a owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label      "Radiation Risk"@en ;
    rdfs:comment    "Riesgo asociado a la exposición inadvertida o excesiva a radiación ionizante o no ionizante."@en .

:InterferenceRisk a owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label      "Interference Risk"@en ;
    rdfs:comment    "Riesgo por interferencias electromagnéticas o artefactos producidos por el dispositivo."@en .

:DiagnosticRisk a owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label      "Diagnostic Risk"@en ;
    rdfs:comment    "Riesgo específico de dispositivos IVD: falsos positivos, falsos negativos, reactividad cruzada, etc."@en .

:ContaminationRisk a owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label      "Contamination Risk"@en ;
    rdfs:comment    "Riesgo de contaminación del producto o de sus reactivos."@en .

:CybersecurityRisk a owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label      "Cybersecurity Risk"@en ;
    rdfs:comment    "Riesgo derivado de vulnerabilidades de ciberseguridad del dispositivo."@en .

:MaterialRisk a owl:Class ;
    rdfs:subClassOf :Risk ;
    rdfs:label      "Material Risk"@en ;
    rdfs:comment    "Riesgo derivado de los materiales del dispositivo (desgaste, corrosión, toxicidad)."@en .

### Incidentes

:Incident a owl:Class ;
    rdfs:subClassOf :RegulatedEntity ;
    rdfs:label      "Incident"@en ;
    rdfs:comment    "Evento adverso asociado a un dispositivo médico que es notificado a las autoridades regulatorias a través de EUDAMED."@en ;
    rdfs:subClassOf [
        a owl:Restriction ;
        owl:onProperty  :affects ;
        owl:someValuesFrom :MedicalDevice
    ] .

:SeriousIncident a owl:Class ;
    rdfs:subClassOf :Incident ;
    rdfs:label      "Serious Incident"@en ;
    rdfs:comment    "Incidente grave que provoca, o pudo haber provocado, la muerte del paciente o un deterioro grave de su salud."@en .

:NearMissIncident a owl:Class ;
    rdfs:subClassOf :Incident ;
    rdfs:label      "Near-Miss Incident"@en ;
    rdfs:comment    "Cuasi-incidente detectado sin consecuencias finales sobre el paciente."@en .

### Acciones correctivas (FSCA)

:CorrectiveAction a owl:Class ;
    rdfs:subClassOf :RegulatedEntity ;
    rdfs:label      "Field Safety Corrective Action"@en ;
    rdfs:comment    "Acción correctiva de seguridad en campo (FSCA) emprendida por el fabricante para reducir el riesgo asociado a un dispositivo comercializado."@en .

:Recall a owl:Class ;
    rdfs:subClassOf :CorrectiveAction ;
    rdfs:label      "Recall"@en ;
    rdfs:comment    "Retirada de producto del mercado."@en .

:SafetyAlert a owl:Class ;
    rdfs:subClassOf :CorrectiveAction ;
    rdfs:label      "Safety Alert"@en ;
    rdfs:comment    "Comunicación de seguridad sin retirada del producto."@en .

:UserNotice a owl:Class ;
    rdfs:subClassOf :CorrectiveAction ;
    rdfs:label      "User Notice"@en ;
    rdfs:comment    "Notificación al usuario con instrucciones de uso actualizadas."@en .

:InSituCorrection a owl:Class ;
    rdfs:subClassOf :CorrectiveAction ;
    rdfs:label      "In Situ Correction"@en ;
    rdfs:comment    "Corrección del dispositivo en el centro de uso (actualización software, cambio de consumible, reentrenamiento…)."@en .

### Clases disjuntas (para favorecer el razonamiento)

[] a owl:AllDisjointClasses ;
    owl:members ( :MDRRiskClass :IVDRRiskClass ) .

[] a owl:AllDisjointClasses ;
    owl:members ( :SeriousIncident :NearMissIncident ) .

[] a owl:AllDisjointClasses ;
    owl:members ( :Recall :SafetyAlert :UserNotice :InSituCorrection ) .

#################################################################
#  PROPIEDADES DE OBJETO (REQ-4)
#################################################################

:hasManufacturer a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range  :Manufacturer ;
    rdfs:label   "has manufacturer"@en ;
    rdfs:comment "Relaciona un dispositivo con su fabricante legal. Es funcional: un dispositivo tiene un único fabricante registrado."@en .

:manufacturesDevice a owl:ObjectProperty ;
    owl:inverseOf :hasManufacturer ;
    rdfs:domain :Manufacturer ;
    rdfs:range  :MedicalDevice ;
    rdfs:label   "manufactures device"@en ;
    rdfs:comment "Inversa de hasManufacturer."@en .

:hasRiskClass a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range  :RiskClass ;
    rdfs:label   "has risk class"@en ;
    rdfs:comment "Clase de riesgo asignada al dispositivo (una y solo una conforme al MDR o IVDR)."@en .

:regulatedBy a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range  :RegulatoryFramework ;
    rdfs:label   "regulated by"@en ;
    rdfs:comment "Marco regulatorio bajo el que se clasifica el dispositivo (MDR o IVDR)."@en .

:hasIdentifiedRisk a owl:ObjectProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range  :Risk ;
    rdfs:label   "has identified risk"@en ;
    rdfs:comment "Riesgo identificado que afecta a un dispositivo o a su tipología."@en .

:locatedInCountry a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range  :Country ;
    rdfs:label   "located in country"@en ;
    rdfs:comment "País en el que tiene sede legal el fabricante."@en .

:supervisedBy a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range  :CompetentAuthority ;
    rdfs:label   "supervised by"@en ;
    rdfs:comment "Autoridad competente del Estado miembro bajo cuya supervisión opera el fabricante."@en .

:affects a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain :Incident ;
    rdfs:range  :MedicalDevice ;
    rdfs:label   "affects"@en ;
    rdfs:comment "Dispositivo concreto al que se refiere un incidente."@en .

:triggeredBy a owl:ObjectProperty ;
    rdfs:domain :Incident ;
    rdfs:range  :Risk ;
    rdfs:label   "triggered by"@en ;
    rdfs:comment "Riesgo identificado que materializa el incidente."@en .

:hasCorrectiveAction a owl:ObjectProperty ;
    rdfs:domain :Incident ;
    rdfs:range  :CorrectiveAction ;
    rdfs:label   "has corrective action"@en ;
    rdfs:comment "FSCA derivada de un incidente."@en .

:reportedInCountry a owl:ObjectProperty ;
    rdfs:domain :Incident ;
    rdfs:range  :Country ;
    rdfs:label   "reported in country"@en ;
    rdfs:comment "Estado miembro en el que se notifica el incidente."@en .

#################################################################
#  PROPIEDADES DE DATOS (REQ-5)
#################################################################

:deviceName a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range  xsd:string ;
    rdfs:label   "device name"@en ;
    rdfs:comment "Nombre comercial del dispositivo tal y como aparece en EUDAMED."@en .

:udiDi a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range  xsd:string ;
    rdfs:label   "UDI-DI"@en ;
    rdfs:comment "Unique Device Identifier – Device Identifier (GS1 AI 01). Es único e inmutable para el modelo de dispositivo."@en .

:intendedPurpose a owl:DatatypeProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range  xsd:string ;
    rdfs:label   "intended purpose"@en ;
    rdfs:comment "Finalidad prevista declarada por el fabricante."@en .

:isImplantable a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range  xsd:boolean ;
    rdfs:label   "is implantable"@en ;
    rdfs:comment "Valor booleano que indica si el dispositivo es implantable."@en .

:isActive a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range  xsd:boolean ;
    rdfs:label   "is active"@en ;
    rdfs:comment "Valor booleano que indica si el dispositivo es activo (requiere fuente de energía externa)."@en .

:isIvd a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range  xsd:boolean ;
    rdfs:label   "is IVD"@en ;
    rdfs:comment "Valor booleano que indica si el dispositivo es de diagnóstico in vitro."@en .

:isReusable a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :MedicalDevice ;
    rdfs:range  xsd:boolean ;
    rdfs:label   "is reusable"@en ;
    rdfs:comment "Valor booleano que indica si el dispositivo se utiliza en más de un paciente o procedimiento."@en .

:authorizationNumber a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range  xsd:string ;
    rdfs:label   "authorization number"@en ;
    rdfs:comment "Número de autorización asignado al fabricante por la autoridad competente."@en .

:eudamedSRN a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range  xsd:string ;
    rdfs:label   "EUDAMED SRN"@en ;
    rdfs:comment "Single Registration Number de EUDAMED asignado al fabricante."@en .

:contactEmail a owl:DatatypeProperty ;
    rdfs:domain :Manufacturer ;
    rdfs:range  xsd:string ;
    rdfs:label   "contact email"@en ;
    rdfs:comment "Correo de contacto regulatorio del fabricante."@en .

:imdrfCode a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :Risk ;
    rdfs:range  xsd:string ;
    rdfs:label   "IMDRF code"@en ;
    rdfs:comment "Código IMDRF Adverse Event Terminology que identifica el riesgo."@en .

:severity a owl:DatatypeProperty ;
    rdfs:domain :Risk ;
    rdfs:range  xsd:string ;
    rdfs:label   "severity"@en ;
    rdfs:comment "Gravedad del riesgo (Moderate, Serious, Critical)."@en .

:probability a owl:DatatypeProperty ;
    rdfs:domain :Risk ;
    rdfs:range  xsd:string ;
    rdfs:label   "probability"@en ;
    rdfs:comment "Probabilidad estimada de materialización del riesgo (Low, Medium, High)."@en .

:eventDate a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :Incident ;
    rdfs:range  xsd:date ;
    rdfs:label   "event date"@en ;
    rdfs:comment "Fecha en la que tuvo lugar el evento adverso."@en .

:reportDate a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :Incident ;
    rdfs:range  xsd:date ;
    rdfs:label   "report date"@en ;
    rdfs:comment "Fecha en la que el incidente fue notificado a la autoridad competente."@en .

:incidentDescription a owl:DatatypeProperty ;
    rdfs:domain :Incident ;
    rdfs:range  xsd:string ;
    rdfs:label   "incident description"@en ;
    rdfs:comment "Descripción clínica del incidente."@en .

:actionDate a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :CorrectiveAction ;
    rdfs:range  xsd:date ;
    rdfs:label   "action date"@en ;
    rdfs:comment "Fecha en la que se inicia la FSCA."@en .

:closureDate a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :CorrectiveAction ;
    rdfs:range  xsd:date ;
    rdfs:label   "closure date"@en ;
    rdfs:comment "Fecha de cierre de la FSCA (si procede)."@en .

:fscaStatus a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain :CorrectiveAction ;
    rdfs:range  xsd:string ;
    rdfs:label   "FSCA status"@en ;
    rdfs:comment "Estado de la acción correctiva (Open, Closed)."@en .

:devicesAffected a owl:DatatypeProperty ;
    rdfs:domain :CorrectiveAction ;
    rdfs:range  xsd:string ;
    rdfs:label   "devices affected"@en ;
    rdfs:comment "Número (aproximado) de dispositivos alcanzados por la FSCA."@en .

#################################################################
#  RESTRICCIONES DE CLASE (REQ-6)
#################################################################

:MedicalDevice rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty   :hasManufacturer ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass      :Manufacturer
] .

:MedicalDevice rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty   :hasRiskClass ;
    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
    owl:onClass      :RiskClass
] .

:InVitroDiagnosticDevice rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty    :hasRiskClass ;
    owl:someValuesFrom :IVDRRiskClass
] .

:ImplantableDevice rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty    :hasRiskClass ;
    owl:someValuesFrom :MDRRiskClass
] .

:Incident rdfs:subClassOf [
    a owl:Restriction ;
    owl:onProperty    :affects ;
    owl:someValuesFrom :MedicalDevice
] .

#################################################################
#  CLASES DE RIESGO (instancias nombradas)
#
#  Se modelan como individuos (NamedIndividual), no como
#  clases, para evitar el patrón de *punning* al ser a la vez
#  valor de la propiedad de objeto :hasRiskClass.
#################################################################

:ClassI a owl:NamedIndividual , :MDRRiskClass ;
    rdfs:label   "Class I (MDR)"@en ;
    rdfs:comment "Clase de riesgo I bajo MDR: riesgo bajo."@en .

:ClassIIa a owl:NamedIndividual , :MDRRiskClass ;
    rdfs:label   "Class IIa (MDR)"@en ;
    rdfs:comment "Clase de riesgo IIa bajo MDR: riesgo medio-bajo."@en .

:ClassIIb a owl:NamedIndividual , :MDRRiskClass ;
    rdfs:label   "Class IIb (MDR)"@en ;
    rdfs:comment "Clase de riesgo IIb bajo MDR: riesgo medio-alto."@en .

:ClassIII a owl:NamedIndividual , :MDRRiskClass , :HighRiskClassCategory ;
    rdfs:label   "Class III (MDR)"@en ;
    rdfs:comment "Clase de riesgo III bajo MDR: riesgo alto."@en .

:ClassA a owl:NamedIndividual , :IVDRRiskClass ;
    rdfs:label   "Class A (IVDR)"@en ;
    rdfs:comment "Clase de riesgo A bajo IVDR: riesgo bajo individual y para la salud pública."@en .

:ClassB a owl:NamedIndividual , :IVDRRiskClass ;
    rdfs:label   "Class B (IVDR)"@en ;
    rdfs:comment "Clase de riesgo B bajo IVDR."@en .

:ClassC a owl:NamedIndividual , :IVDRRiskClass ;
    rdfs:label   "Class C (IVDR)"@en ;
    rdfs:comment "Clase de riesgo C bajo IVDR."@en .

:ClassD a owl:NamedIndividual , :IVDRRiskClass , :HighRiskClassCategory ;
    rdfs:label   "Class D (IVDR)"@en ;
    rdfs:comment "Clase de riesgo D bajo IVDR: riesgo más alto tanto individual como para la salud pública."@en .

#################################################################
#  INDIVIDUOS – Países (con enlaces REQ-9 a DBpedia)
#################################################################

:Germany a owl:NamedIndividual , :Country ;
