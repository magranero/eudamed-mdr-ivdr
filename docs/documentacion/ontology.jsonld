}, {
  "@id" : "http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ActiveDevice",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Dispositivo médico que depende de una fuente de energía distinta de la generada directamente por el cuerpo humano o la gravedad."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Active Device"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#MedicalDevice"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ActiveImplant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Implante activo en el sentido del MDR, anexo VIII regla 8: dispositivo activo destinado a introducirse total o parcialmente en el cuerpo humano y permanecer tras la intervención."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@language" : "en",
    "@value" : "Active Implant"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/ontologies/eudamed-mdr-ivdr#ImplantableActiveDevice"
  } ]
